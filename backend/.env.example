# PostgreSQL
DATABASE_URL=postgresql://youruser@localhost:5432/sonar

# JWT
JWT_SECRET_KEY=change-me-to-a-real-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Logging
LOG_LEVEL=INFO

# ── AI Emotion Analysis (fallback: NVIDIA NIM → Groq → Together AI) ──
# At least ONE key is required for mood analysis to work.
# NVIDIA NIM (PRIMARY): https://build.nvidia.com/
NVIDIA_NIM_API_KEY=
# Groq (SECONDARY): https://console.groq.com/keys
GROQ_API_KEY=
# Together AI (LAST RESORT): https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# ── Voice Transcription (fallback: Deepgram → AssemblyAI) ──
# Deepgram (RECOMMENDED, FREE 12k min/month): https://deepgram.com/
DEEPGRAM_API_KEY=
# AssemblyAI (FREE 5 hrs/month): https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=

# ── Weather (OPTIONAL — for weather-influenced genre suggestions) ──
# Get from: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=

# ── Spotify (REQUIRED for playlist generation) ──
# Get from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
